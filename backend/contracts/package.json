{
  "name": "@loreloom/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Loreloom Genesis and Chapter ERC-721 contracts",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "clean": "hardhat clean",
    "role:minter": "node scripts/print-minter-role.js",
    "deploy:testnet:plan": "npm run compile && node scripts/deploy-xlayer-testnet.js",
    "deploy:testnet": "npm run compile && node scripts/deploy-xlayer-testnet.js --execute",
    "deploy:testnet:direct": "hardhat run scripts/deploy-direct-xlayer-testnet.js --network xlayerTestnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.28.6"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.1.0",
    "dotenv": "^16.4.7"
  }
}
