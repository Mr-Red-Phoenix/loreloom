# Shared local development
PORT=4000
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Worker
WORKER_ID=loreloom-worker-local
WORKER_POLL_INTERVAL_MS=2000
WORKER_IDLE_SLEEP_MS=2000

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=Loreloom

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_IMAGE_FAST_MODEL=gemini-3.1-flash-lite-image
GEMINI_IMAGE_PRO_MODEL=gemini-3-pro-image

# NVIDIA NIM
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_IMAGE_MODEL=flux.1-schnell

# Hugging Face Inference Providers image fallback
HUGGINGFACE_API_KEY=
HUGGINGFACE_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# OpenRouter image generation fallback
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image

# IPFS / Minting
IPFS_MODE=mock
PINATA_JWT=
MINT_MODE=mock
THIRDWEB_CLIENT_ID=
THIRDWEB_SECRET_KEY=
# Current thirdweb Wallets / Transactions v3 path.
# The Vault token is optional for projects where secret-key auth can operate the
# configured server wallet directly.
THIRDWEB_VAULT_ACCESS_TOKEN=
THIRDWEB_TRANSACTIONS_URL=https://engine.thirdweb.com

# Legacy thirdweb Engine v2 path. Only needed if MINT_MODE=thirdweb-engine.
THIRDWEB_ENGINE_URL=
THIRDWEB_ENGINE_ACCESS_TOKEN=
THIRDWEB_BACKEND_WALLET_ADDRESS=
# X Layer testnet. Use 196 only when deliberately switching to mainnet.
X_LAYER_CHAIN_ID=1952
X_LAYER_RPC_URL=https://testrpc.xlayer.tech/terigon
THIRDWEB_DEPLOYER_ADDRESS=
# Required only for the direct X Layer testnet fallback. Use a fresh test-only EOA.
X_LAYER_DEPLOYER_PRIVATE_KEY=
GENESIS_CONTRACT_ADDRESS=
CHAPTER_CONTRACT_ADDRESS=
